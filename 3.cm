/* 3.cm
   Valid program.
   Tests global arrays, array parameters, while-loops,
   function calls, and accumulation.
*/

int x[5];

int sumArray(int a[], int n) {
  int i;
  int sum;

  i = 0;
  sum = 0;

  while (i < n) {
    sum = sum + a[i];
    i = i + 1;
  }

  return sum;
}

void main(void) {
  int result;

  x[0] = 4;
  x[1] = 1;
  x[2] = 3;
  x[3] = 2;
  x[4] = 10;

  result = sumArray(x, 5);
  output(result);
}